# ============================================================
# Outreach Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All variables prefixed with VITE_ are exposed to the frontend.

# Server
PORT=3000

# Google Gemini API Key (required for AI features, fallback mode if missing)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Firebase (optional — app runs in Sandbox Mode without these)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=
