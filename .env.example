# ============================================================
# Outreach Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All variables prefixed with VITE_ are exposed to the frontend.

# Server
PORT=3000

# Google Gemini API Key (required for AI features, fallback mode if missing)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Firebase Client SDK (browser + Vite) ──────────────────────────────────────
# From: Firebase Console > Project Settings > Your Apps > Web App
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=

# ── Firebase Admin SDK (server-side background scheduler) ────────────────────
# The background scheduler uses Admin SDK to read/write Firestore without a browser.
#
# Option A — Service Account JSON (recommended for local dev):
#   1. Go to Firebase Console > Project Settings > Service Accounts
#   2. Click "Generate new private key" -> save as service-account.json in project root
#   3. Set the path below:
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
#
# Option B — Application Default Credentials (Cloud Run / GCP VM):
#   Just leave GOOGLE_APPLICATION_CREDENTIALS blank; gcloud auth will be used.
#
# Either way, also set:
FIREBASE_PROJECT_ID=          # same as VITE_FIREBASE_PROJECT_ID
FIREBASE_DATABASE_ID=         # same as VITE_FIREBASE_DATABASE_ID (or "(default)")
