rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entities Validations helpers
    // Basic Validations
    function isValidUser(data) {
      return data.keys().hasAny(['email', 'displayName', 'photoURL', 'createdAt']);
    }

    // Rules matching individual partitions
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow delete: if false; // Deny user profile deletion via direct Web SDK for safety

      // V3 Collections: fully isolated to the owner
      match /resumes/{docId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
      match /contacts/{docId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
      match /applications/{docId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
      match /settings/{docId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
      match /campaigns/{docId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
      match /emailQueue/{docId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
      match /companyResearch/{docId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
      match /generatedEmails/{docId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
      match /reports/{docId} {
        allow read, write: if isOwner(userId) && isValidId(userId);
      }
    }
  }
}
